R2_PUBLIC_DOMAIN=your-bucket.r2.dev

# Internal API key (for inter-service communication)
INTERNAL_API_KEY=change-me-to-a-random-secret

# Sentry
SENTRY_DSN=

# App
PORT=3000
BASE_URL=http://localhost:3000
